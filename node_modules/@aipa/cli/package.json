{
  "name": "@aipa/cli",
  "version": "1.0.0",
  "description": "AIPA Studio CLI",
  "bin": {
    "aipa": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "inquirer": "^10.1.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "axios": "^1.7.2",
    "eventsource": "^2.0.2",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "tsup": "^8.1.0",
    "tsx": "^4.11.2",
    "vitest": "^1.6.0",
    "@types/node": "^20.14.0",
    "@types/js-yaml": "^4.0.9",
    "@types/inquirer": "^9.0.7"
  }
}
