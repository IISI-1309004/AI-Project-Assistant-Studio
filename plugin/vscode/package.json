{
  "name": "@aipa/plugin-vscode",
  "displayName": "AIPA Studio",
  "description": "AI Project Assistant Studio — VSCode Extension",
  "version": "1.0.0",
  "engines": { "vscode": "^1.89.0" },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist"
  },
  "contributes": {
    "commands": [
      { "command": "aipa.ask", "title": "Ask AIPA" }
    ],
    "menus": {
      "editor/context": [
        { "command": "aipa.ask", "group": "aipa" }
      ]
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.89.0",
    "typescript": "^5.4.5"
  }
}
