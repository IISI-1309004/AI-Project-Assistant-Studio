# =============================================================================
# AIPA Studio Docker 環境設定
#
# 複製此檔案為 `.env` 並填入適當值後啟動容器：
#   cp .env.example .env
#   docker compose up -d
# =============================================================================

# AI 供應商 API Keys（至少填入一項）
# 支援的供應商：Claude, OpenAI, Gemini, Ollama (本地)
CLAUDE_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
GEMINI_API_KEY=your-gemini-key-here

# 主要 AI 供應商 — 優先順序（claude | openai | gemini | ollama）
AIPA_PRIMARY_ADAPTER=claude

# PostgreSQL 資料庫設定
POSTGRES_USER=aipa
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=aipa

# 儲存後端（postgresql | sqlite，推薦生產環境用 postgresql）
AIPA_STORAGE_BACKEND=postgresql

# AI 引擎信心閾值（範圍: 60–90，預設: 70）
# 低於此閾值的 AI 建議需要額外審核
AIPA_CONFIDENCE_THRESHOLD=70

# 工作階段超時（秒數，預設: 3600 = 1 小時）
AIPA_SESSION_TIMEOUT_SECONDS=3600

# 記憶強度衰減因子（0–1，預設: 0.95）
AIPA_MEMORY_DECAY_FACTOR=0.95

# 規則引擎模式（strict | permissive，預設: permissive）
AIPA_WISDOM_MODE=permissive


